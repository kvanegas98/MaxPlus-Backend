## [Visual Studio]
## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.resharper.user
*.dotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017+ cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework Core
*.design.time.lock.json

# BOWER
bower_components/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Repository Config
# [Nn]u[G]et.config

# User Secrets
appsettings.Development.json
secrets.json

# MSBuild
*.device.targets

# Service Fabric
**/[Pp]ublishProfiles/
**/[Pp]ackageRoot/
**/[Cc]onfigRoot/

## [Visual Studio Code]
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

## [JetBrains]
.idea/
*.iws
*.out
.shelf/

## [Operating Systems]
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

## [Database]
*.mdf
*.ldf
*.ndf
*.bak

## [Misc]
.gemini/
.agent/
.agents/
brain/
*.~
